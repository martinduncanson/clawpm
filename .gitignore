mcps/

# Example portfolio fixtures need .project/ committed for onboarding
!examples/**/.project/
!examples/**/.project/**

# ...but never the runtime lock sentinel, even under examples (CLAWP-051). This
# must come AFTER the negation above, or running clawpm against an example
# portfolio leaves the sentinel committable (Codex review).
examples/**/.project/**/.clawpm-tasks.lock
